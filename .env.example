# Copy to .env.local and fill in real values. .env.local is gitignored.
# Every env var read by anything in shared/ should be documented here.

# --- Supabase ------------------------------------------------------------
# Project URL. Local dev: http://127.0.0.1:54321 (from `supabase status`).
# Cloud: Project Settings → API → Project URL on the Supabase dashboard.
SUPABASE_URL=http://127.0.0.1:54321

# Service role key — bypasses RLS. Server-side only, never ship to the browser.
# Local dev: `supabase status` prints it as "Secret". Cloud: Project Settings →
# API → Project API keys → service_role (secret) on the dashboard.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# --- Anthropic (Claude) --------------------------------------------------
# Claude API key. Used by shared/claude_client.py for every agent call.
# Create at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=replace-me

# --- OpenAI (embeddings) -------------------------------------------------
# OpenAI API key. Used by shared/kb_query.py for text-embedding-3-small.
# Embedding model only — generation still goes through Anthropic.
# Create at https://platform.openai.com/api-keys.
OPENAI_API_KEY=replace-me

# --- Slack ----------------------------------------------------------------
# Bot User OAuth Token for Slack ingestion and Ella's bot responses.
# Starts with xoxb-. From api.slack.com/apps → your app → OAuth & Permissions.
SLACK_BOT_TOKEN=replace-me
